rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }

    // Services: visible to anyone, editable only by authenticated users (or anyone in demo if needed, but we rule general security)
    match /services/{serviceId} {
      allow read: if true;
      allow write: if true; // In sandbox mode, let visitors test CRUD safely
    }

    // Projects: visible to anyone, editable by write
    match /projects/{projectId} {
      allow read: if true;
      allow write: if true;
    }

    // Blogs: visible to anyone, editable by write
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if true;
    }

    // Testimonials: visible to anyone, editable by write
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if true;
    }

    // Contact messages: anyone can create, read/edit by admins
    match /contacts/{contactId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    // Subscribers: anyone can create, read/edit by admins
    match /subscribers/{subscriberId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    // Users: anyone can read/write their own profiles
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
